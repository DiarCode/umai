// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/common/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}



enum PlatformAdminRole {
  SUPER_ADMIN
  ANALYST
  SUPPORT
}

enum EmployeeRoleName {
  DIRECTOR
  MANAGER
  WAITER
  CASHIER
  KITCHEN
}

enum OrderChannel {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ONLINE
}

enum OrderStatus {
  PLACED
  ACCEPTED
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  ONLINE
  CASH
  OTHER
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  PROCESSING
  SUCCEEDED
  CANCELED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum MediaAssetType {
  IMAGE
  MODEL_3D
  VIDEO
  AUDIO
}

enum ProductAssetKind {
  PHOTO
  MODEL_3D
  THUMBNAIL
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

////////////////////////////////////////////////////////////
// PLATFORM ADMINS (superadmin / developers / analytics)
////////////////////////////////////////////////////////////

model PlatformAdmin {
  id           String            @id @default(uuid()) @db.Uuid
  email        String            @unique @db.VarChar(255)
  passwordHash String
  fullName     String?           @db.VarChar(255)
  role         PlatformAdminRole @default(SUPER_ADMIN)
  isActive     Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

////////////////////////////////////////////////////////////
// CUSTOMERS (optional registration)
////////////////////////////////////////////////////////////

model Customer {
  id        String  @id @default(uuid()) @db.Uuid
  email     String? @unique @db.VarChar(255)
  phone     String? @db.VarChar(32)
  fullName  String? @db.VarChar(255)

  // optional: last-seen locale preferences etc.
  locale    String? @db.VarChar(16)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

////////////////////////////////////////////////////////////
// RESTAURANTS (tenant root)
////////////////////////////////////////////////////////////

model Restaurant {
  id          String  @id @default(uuid()) @db.Uuid
  slug        String  @unique @db.VarChar(80)
  name        String  @db.VarChar(255)
  description String? @db.Text

  phone       String? @db.VarChar(32)
  email       String? @db.VarChar(255)

  addressLine1 String? @db.VarChar(255)
  addressLine2 String? @db.VarChar(255)
  city         String? @db.VarChar(120)
  countryCode  String? @db.VarChar(2)

  timezone     String  @default("UTC") @db.VarChar(64)
  currency     String  @default("USD") @db.VarChar(3)

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  // Flexible settings: tax rules, service fee flags, AI voice config, etc.
  settings Json?

  categories Category[]
  products   Product[]
  tables     RestaurantTable[]
  employees  RestaurantEmployee[]
  orders     Order[]
  assets     MediaAsset[]
  hours      RestaurantOperatingHours[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantOperatingHours {
  id           String    @id @default(uuid()) @db.Uuid
  restaurantId String    @db.Uuid
  dayOfWeek    DayOfWeek

  // stored as TIME in Postgres (Prisma uses DateTime scalar with @db.Time)
  openTime     DateTime  @db.Time
  closeTime    DateTime  @db.Time

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
}

////////////////////////////////////////////////////////////
// EMPLOYEES + ROLES (roles attached to a restaurant employee)
////////////////////////////////////////////////////////////

model RestaurantEmployee {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @db.Uuid

  email        String? @db.VarChar(255)
  phone        String? @db.VarChar(32)
  passwordHash String?
  fullName     String? @db.VarChar(255)

  isActive Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  roles      RestaurantEmployeeRole[]

  createdOrders Order[] @relation("OrderCreatedByEmployee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // allow same email across different restaurants (or keep global unique if you prefer)
  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([phone])
}

model RestaurantEmployeeRole {
  id         String           @id @default(uuid()) @db.Uuid
  employeeId String           @db.Uuid
  role       EmployeeRoleName

  employee RestaurantEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, role])
  @@index([employeeId])
}

////////////////////////////////////////////////////////////
// MENU: CATEGORIES + PRODUCTS
////////////////////////////////////////////////////////////

model Category {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @db.Uuid

  name      String  @db.VarChar(120)
  slug      String  @db.VarChar(120)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, slug])
  @@index([restaurantId])
}

model Product {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @db.Uuid
  categoryId   String? @db.Uuid

  name        String  @db.VarChar(255)
  slug        String  @db.VarChar(160)
  description String? @db.Text

  // money
  price    Decimal @db.Decimal(12, 2)
  currency String  @db.VarChar(3)

  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  // AR/food metadata (keep flexible)
  nutrition Json?
  allergens Json?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  assets    ProductAsset[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@index([categoryId])
}

////////////////////////////////////////////////////////////
// MEDIA / AR ASSETS (S3/MinIO keys + metadata)
////////////////////////////////////////////////////////////

model MediaAsset {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @db.Uuid

  type       MediaAssetType
  storageKey String        @unique @db.VarChar(512) // e.g., s3 key / minio object path
  mimeType   String?       @db.VarChar(120)
  fileSize   Int?
  checksum   String?       @db.VarChar(128)

  // for images/video
  width      Int?
  height     Int?
  durationMs Int?

  // for 3D models: scale, format, units, bounding box, etc.
  meta Json?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  productLinks ProductAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([type])
}

model ProductAsset {
  id        String          @id @default(uuid()) @db.Uuid
  productId String          @db.Uuid
  assetId   String          @db.Uuid

  kind      ProductAssetKind
  sortOrder Int @default(0)

  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset   MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([productId, assetId, kind])
  @@index([productId])
  @@index([assetId])
}

////////////////////////////////////////////////////////////
// TABLES + QR + SESSIONS
////////////////////////////////////////////////////////////

model RestaurantTable {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @db.Uuid

  label    String  @db.VarChar(40) // e.g., "T1", "VIP-2"
  capacity Int?
  isActive Boolean @default(true)

  // encode this value into the printed QR; keep long and random
  qrCode String @unique @db.VarChar(128)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, label])
  @@index([restaurantId])
}


////////////////////////////////////////////////////////////
// ORDERS + ITEMS + PAYMENTS
////////////////////////////////////////////////////////////

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  restaurantId String      @db.Uuid
  tableSessionId String?   @db.Uuid
  customerId   String?     @db.Uuid

  // human-friendly number per restaurant (generate in app transaction)
  orderNumber  Int?

  channel OrderChannel @default(DINE_IN)
  status  OrderStatus  @default(PLACED)

  notes String? @db.Text

  // guest checkout (when customerId is null)
  guestName  String? @db.VarChar(255)
  guestPhone String? @db.VarChar(32)
  guestEmail String? @db.VarChar(255)

  currency String @db.VarChar(3)

  subtotal    Decimal @db.Decimal(12, 2)
  tax         Decimal @db.Decimal(12, 2) @default(0)
  serviceFee  Decimal @db.Decimal(12, 2) @default(0)
  discount    Decimal @db.Decimal(12, 2) @default(0)
  total       Decimal @db.Decimal(12, 2)

  placedAt    DateTime?
  completedAt DateTime?

  createdByEmployeeId String? @db.Uuid

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdByEmployee RestaurantEmployee? @relation("OrderCreatedByEmployee", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)

  items    OrderItem[]
  payment  Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([tableSessionId])
  @@index([customerId])
  @@index([status])
  @@unique([restaurantId, orderNumber])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String  @db.Uuid

  quantity Int @default(1)

  // snapshots (immutable for order history correctness)
  nameSnapshot       String  @db.VarChar(255)
  unitPriceSnapshot  Decimal @db.Decimal(12, 2)
  totalPriceSnapshot Decimal @db.Decimal(12, 2)

  notes String? @db.Text

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id           String          @id @default(uuid()) @db.Uuid
  orderId      String          @unique @db.Uuid

  provider     PaymentProvider @default(ONLINE)
  status       PaymentStatus   @default(REQUIRES_PAYMENT_METHOD)

  amount       Decimal         @db.Decimal(12, 2)
  currency     String          @db.VarChar(3)

  // Stripe: PaymentIntent id (pi_...), or other provider’s intent/txn id
  providerRef  String?         @db.VarChar(255)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider])
  @@index([status])
}